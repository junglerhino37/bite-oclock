# Copy to .env.local and fill in YOUR OWN keys — never commit real values.
# Every feature degrades gracefully when a key is missing (demo mode), so you
# can develop most of the site with no keys at all.

# — AI (server-side only; never exposed to the browser) —
# Enables real menu extraction (/api/extract) and NL search (/api/ask).
# Get a key at https://console.anthropic.com — set a spend limit there too.
ANTHROPIC_API_KEY=

# Optional model overrides (defaults: claude-haiku-4-5-20251001)
# EXTRACTION_MODEL=
# QUERY_MODEL=

# — Supabase (uploads/database; not required for the demo site) —
# Create a free project at https://supabase.com or run `supabase start` locally.
SUPABASE_URL=
# service_role key: SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# — Sign-in (optional; enables Google/Facebook login for verification votes) —
# Same project URL as above, plus the anon key. Both are safe for the browser
# ONLY because RLS is enabled on every table. Also enable the Google/Facebook
# providers in the Supabase dashboard (Authentication → Providers).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
